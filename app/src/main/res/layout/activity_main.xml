<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal">

    <!-- ===== SIDEBAR ===== -->
    <LinearLayout
        android:id="@+id/sidebar"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:background="#1a1a2e"
        android:orientation="vertical">

        <!-- Sidebar Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:background="#2D2B55">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="AI Assistant Pro"
                android:textColor="#ffffff"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/sidebar_new_chat"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="＋"
                android:textColor="#6C63FF"
                android:textSize="20sp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <TextView
            android:id="@+id/status_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingVertical="4dp"
            android:text="Ready to assist"
            android:textColor="#6C63FF"
            android:textSize="10sp"
            android:gravity="center" />

        <!-- Folders Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="FOLDERS"
                    android:textColor="#555577"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textAllCaps="true" />

                <TextView
                    android:id="@+id/btn_add_folder"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+ Add"
                    android:textColor="#6C63FF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:padding="4dp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxHeight="150dp">

                <LinearLayout
                    android:id="@+id/folder_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="4dp" />
            </ScrollView>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2D2B55"
            android:layout_marginVertical="4dp" />

        <!-- Conversations Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="CONVERSATIONS"
                android:textColor="#555577"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textAllCaps="true" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <LinearLayout
                    android:id="@+id/conversation_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingBottom="8dp" />
            </ScrollView>
        </LinearLayout>

        <!-- Bottom Settings -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#2D2B55"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:clickable="true"
            android:focusable="true"
            android:id="@+id/settings_button">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚙"
                android:textColor="#6C63FF"
                android:textSize="16sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Settings &amp; API"
                android:textColor="#888899"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- ===== MAIN CHAT AREA ===== -->
    <FrameLayout
        android:id="@+id/main_content"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="#16213e">

        <!-- Empty State (shown when no conversation selected) -->
        <LinearLayout
            android:id="@+id/empty_state"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="40dp"
            android:visibility="visible">

            <TextView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:gravity="center"
                android:text="🤖"
                android:textSize="40sp"
                android:background="#2D2B55"
                android:backgroundTint="#2D2B55" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="AI Assistant Pro"
                android:textColor="#ffffff"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Start a conversation or select one from the sidebar"
                android:textColor="#666688"
                android:textSize="13sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Try these:"
                android:textColor="#555577"
                android:textSize="11sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/prompt_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp"
                    android:layout_marginBottom="8dp"
                    android:text="Write a professional email"
                    android:textColor="#6C63FF"
                    android:background="#2D2B55"
                    android:backgroundTint="#2D2B55"
                    android:textSize="13sp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/prompt_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp"
                    android:layout_marginBottom="8dp"
                    android:text="Summarize this article for me"
                    android:textColor="#6C63FF"
                    android:background="#2D2B55"
                    android:backgroundTint="#2D2B55"
                    android:textSize="13sp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/prompt_3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp"
                    android:text="Help me with a research topic"
                    android:textColor="#6C63FF"
                    android:background="#2D2B55"
                    android:backgroundTint="#2D2B55"
                    android:textSize="13sp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>
        </LinearLayout>

        <!-- Chat View (shown when conversation selected) -->
        <LinearLayout
            android:id="@+id/chat_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Chat Header -->
            <LinearLayout
                android:id="@+id/chat_header"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="#1a1a2e"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp">

                <TextView
                    android:id="@+id/chat_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="New conversation"
                    android:textColor="#ffffff"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/btn_delete_conversation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:text="🗑"
                    android:textSize="16sp"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Messages -->
            <ScrollView
                android:id="@+id/chat_scroll"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:padding="12dp">

                <LinearLayout
                    android:id="@+id/chat_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </ScrollView>

            <!-- Input Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="#1a1a2e"
                android:gravity="center_vertical"
                android:paddingHorizontal="8dp">

                <EditText
                    android:id="@+id/message_input"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:hint="Ask me anything..."
                    android:imeOptions="actionSend"
                    android:inputType="text"
                    android:maxLines="3"
                    android:paddingHorizontal="12dp"
                    android:textColor="#ffffff"
                    android:textColorHint="#666688"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/btn_send"
                    android:layout_width="48dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:text="➤"
                    android:backgroundTint="#6C63FF"
                    android:textSize="16sp" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

</LinearLayout>
